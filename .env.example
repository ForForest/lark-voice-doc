# lark-voice-doc — example environment file.
# Copy to `.env` and fill in your own credentials. NEVER commit your real .env.

# ── MiniMax TTS (Chinese voice synthesis) ────────────────────────────────────
MINIMAX_ENDPOINT=https://api.minimaxi.com
MINIMAX_API_KEY=your-minimax-api-key-here

# ── Volcengine (火山) streaming ASR ──────────────────────────────────────────
# App credentials from the Volcengine speech console (流式语音识别 2.0).
VOLC_APP_ID=your-volc-app-id
VOLC_ACCESS_TOKEN=your-volc-access-token
VOLC_SECRET_KEY=your-volc-secret-key
VOLC_ASR_SERVICE=流式语音识别2.0

# ── Doubao Ark (LLM with tool_use; OpenAI-compatible) ────────────────────────
# Primary LLM that drives the agent loop + tool calling.
ARK_API_KEY=your-ark-api-key

# ── DeepSeek (optional backup LLM) ───────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key

# ── Gemini Studio API (optional: whiteboard summarization fallback / A-B) ─────
GEMINI_API_KEY=your-gemini-api-key

# Which model summarizes meeting transcripts into whiteboard diagrams:
#   doubao | gemini-flash   (default: doubao)
WHITEBOARD_LLM=doubao

# ── Server ───────────────────────────────────────────────────────────────────
# Port the local WS/HTTP server listens on.
PORT=3001

# ── Optional: agent / memory configuration ───────────────────────────────────
# Default directory the `search_repo` tool greps when no `dir` is given.
# Leave unset to default to the process working directory.
# TARGET_REPO_DIR=/path/to/your/repo

# Local Claude Code project dir used by the (optional) memory/* tools — holds
# per-session *.jsonl transcripts and a `memory/` subdir of anchor notes.
# Defaults to ~/.claude/projects/<home-slug>. These tools are inert if the dir
# does not exist.
# CLAUDE_PROJECT_DIR=
# CLAUDE_MEMORY_DIR=

# Optional: override the lark-cli per-command timeout (ms, default 60000).
# LARK_CMD_TIMEOUT_MS=60000

# Optional: point the Electron/test clients at a non-default server.
# LARK_VOICE_SERVER=http://localhost:3001
