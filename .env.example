# lark-voice-doc — example environment file.
# Copy to `.env` and fill in your own credentials. NEVER commit your real .env.
#
# Stack is consolidated to 字节火山方舟 only:
#   火山 ASR (streaming STT) + 火山 big-model TTS (Seed-TTS 2.0) + 豆包 Ark LLM.

# ── Volcengine (火山) — streaming ASR + big-model TTS (same app credentials) ──
# App credentials from the Volcengine speech console. The SAME app id + access
# token are reused for both ASR (流式语音识别 2.0) and big-model TTS — but each
# product must be separately enabled ("开通") on the app.
VOLC_APP_ID=your-volc-app-id
VOLC_ACCESS_TOKEN=your-volc-access-token
VOLC_SECRET_KEY=your-volc-secret-key
VOLC_ASR_SERVICE=流式语音识别2.0

# 火山 big-model TTS (Seed-TTS 2.0). These have sane defaults baked into
# src/lib/volc-tts.ts; only set them to override the resource-id / voice.
# VOLC_TTS_RESOURCE_ID=seed-tts-2.0          # or seed-tts-1.0 (faster connect, lower quality)
# VOLC_TTS_VOICE=zh_female_vv_uranus_bigtts  # any 火山 big-model speaker id
# VOLC_TTS_FORMAT=mp3                         # mp3 (default, renderer plays it) | pcm
# VOLC_TTS_SAMPLE_RATE=24000
# Connection pooling (the latency fix — one warm WS reused across utterances):
# VOLC_TTS_IDLE_CONN_MS=90000                # close the warm connection after this idle
# VOLC_TTS_CONNECT_TIMEOUT_MS=20000          # budget for the (cold) connect
# VOLC_TTS_TIMEOUT_MS=20000                  # per-session inactivity watchdog

# ── Doubao Ark (LLM with tool_use; OpenAI-compatible) ────────────────────────
# Drives BOTH the conversational creative-partner agent and the whiteboard
# proposer. Endpoint: https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_API_KEY=your-ark-api-key

# Optional model / thinking overrides (defaults are baked into the code):
#   conversation agent — strongest model + deep thinking (intelligence > latency)
# DOUBAO_AGENT_MODEL=doubao-seed-2-0-pro-260215
# DOUBAO_AGENT_THINKING=enabled              # enabled | auto | disabled
#   whiteboard proposer — fast model so the live board keeps pace with speech
# DOUBAO_WB_MODEL=doubao-seed-2-0-mini-260215

# ── Server ───────────────────────────────────────────────────────────────────
# Port the local WS/HTTP server listens on.
PORT=3001

# ── Optional: agent / memory configuration ───────────────────────────────────
# Default directory the `search_repo` tool greps when no `dir` is given.
# TARGET_REPO_DIR=/path/to/your/repo

# Local Claude Code project dir used by the (optional) memory/* tools.
# Defaults to ~/.claude/projects/<home-slug>. Inert if the dir does not exist.
# CLAUDE_PROJECT_DIR=
# CLAUDE_MEMORY_DIR=

# Optional: override the lark-cli per-command timeout (ms, default 60000).
# LARK_CMD_TIMEOUT_MS=60000

# Optional: point the Electron/test clients at a non-default server.
# LARK_VOICE_SERVER=http://localhost:3001
